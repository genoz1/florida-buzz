<%- include('partials/header', { pageTitle: 'The Florida Buzz — Florida Theme Parks, Beaches, Space & More', category: null, tickerItems: ticker, canonicalPath: '/' }) %>

<main class="wrap">

  <% if (featured) { %>
  <section class="hero">
    <a href="/article/<%= featured.slug %>" class="hero-image">
      <img src="<%= featured.image_url || placeholderImg(featured.category) %>" alt="<%= featured.title %>" width="800" height="600" loading="eager" onerror="this.onerror=null;this.src='<%= placeholderImg(featured.category) %>';">
    </a>
    <div>
      <span class="eyebrow"><%= categoryLabels[featured.category] %></span>
      <a href="/article/<%= featured.slug %>"><h1><%= featured.title %></h1></a>
      <p class="dek"><%= featured.dek %></p>
      <p class="byline">Sourced from <%= featured.source_name %> &middot; <%= timeAgo(featured.published_at) %></p>
    </div>
  </section>
  <% } %>

  <% if (secondary && secondary.length) { %>
  <section class="section">
    <div class="grid">
      <% secondary.forEach(a => { %>
        <a href="/article/<%= a.slug %>" class="card">
          <div class="card-image"><img src="<%= a.image_url || placeholderImg(a.category) %>" alt="<%= a.title %>" width="480" height="300" loading="lazy" onerror="this.onerror=null;this.src='<%= placeholderImg(a.category) %>';"></div>
          <span class="tag <%= a.featured ? 'featured' : '' %>"><%= categoryLabels[a.category] %></span>
          <h3><%= a.title %></h3>
          <p class="dek-sm"><%= a.dek %></p>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <section class="section" style="padding-top:0;">
    <a href="/wait-times" style="display:flex; align-items:center; justify-content:space-between; gap:16px; background:var(--teal-900); color:#fff; border-radius:12px; padding:20px 24px; text-decoration:none; flex-wrap:wrap;">
      <div>
        <span style="font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:#ffb37a;">🎢 Live Right Now</span>
        <div style="font-family:var(--font-display); font-size:22px; margin-top:4px;">Check Current Disney &amp; Universal Wait Times</div>
        <p style="color:#c9dedd; font-size:14px; margin-top:4px;">Real-time ride waits for all 7 major Orlando parks, updated every few minutes.</p>
      </div>
      <span style="background:#fff; color:var(--teal-900); font-weight:700; padding:10px 20px; border-radius:24px; white-space:nowrap;">View Wait Times →</span>
    </a>
  </section>

  <% Object.keys(byCategory).forEach(cat => { %>
    <% if (byCategory[cat].length) { %>
    <section class="section">
      <div class="section-head">
        <span class="section-title"><%= categoryLabels[cat] %></span>
        <a href="/category/<%= cat %>">See all &rarr;</a>
      </div>
      <div class="grid">
        <% byCategory[cat].forEach(a => { %>
          <a href="/article/<%= a.slug %>" class="card">
            <div class="card-image"><img src="<%= a.image_url || placeholderImg(a.category) %>" alt="<%= a.title %>" width="480" height="300" loading="lazy" onerror="this.onerror=null;this.src='<%= placeholderImg(a.category) %>';"></div>
            <h3><%= a.title %></h3>
            <p class="dek-sm"><%= a.dek %></p>
            <p class="byline"><%= timeAgo(a.published_at) %></p>
          </a>
        <% }) %>
      </div>
    </section>
    <% } %>
  <% }) %>

</main>

<%- include('partials/footer') %>
