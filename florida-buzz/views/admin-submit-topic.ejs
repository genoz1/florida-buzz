<%- include('partials/header', { pageTitle: 'Submit a Guide Topic — Florida Buzz Admin', category: null, tickerItems: [], canonicalPath: null }) %>

<main class="wrap">
  <section class="section" style="max-width:560px; margin:0 auto;">
    <h1 style="font-family:var(--font-display); font-size:28px; color:var(--teal-900);">Submit a Guide Topic</h1>
    <p style="color:var(--ink-600); margin-top:6px;">This kicks off the same research-and-write pipeline as the daily automation, but on the exact topic you enter instead of a random pick. Takes a couple minutes to publish after you submit.</p>

    <% if (error) { %>
      <div style="background:#fdecea; color:#b3261e; padding:12px 16px; border-radius:8px; margin-top:16px; font-size:14px;"><%= error %></div>
    <% } %>
    <% if (result) { %>
      <div style="background:#e8f5e9; color:#1b5e20; padding:12px 16px; border-radius:8px; margin-top:16px; font-size:14px;"><%= result %></div>
    <% } %>

    <form method="POST" action="/admin/submit-topic" style="margin-top:24px; display:flex; flex-direction:column; gap:16px;">
      <input type="hidden" name="key" value="<%= adminKey %>">

      <div>
        <label style="display:block; font-weight:600; margin-bottom:6px;">Category</label>
        <select name="category" required style="width:100%; padding:10px 12px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
          <% Object.entries(categoryLabels).forEach(([slug, label]) => { %>
            <option value="<%= slug %>"><%= label %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label style="display:block; font-weight:600; margin-bottom:6px;">Topic</label>
        <textarea name="topic" required rows="3" placeholder="e.g. How DAS (Disability Access Service) registration works in 2026, including the video chat process and what to have ready" style="width:100%; padding:10px 12px; border:1px solid #ccc; border-radius:6px; font-size:15px; font-family:inherit;"></textarea>
        <p style="color:var(--ink-600); font-size:13px; margin-top:4px;">Be specific — this is what the writer researches and covers, so a clear, detailed prompt makes a better guide.</p>
      </div>

      <div>
        <label style="display:block; font-weight:600; margin-bottom:6px;">Working Title</label>
        <input type="text" name="title" required placeholder="e.g. Disney World DAS: How to Register in 2026" style="width:100%; padding:10px 12px; border:1px solid #ccc; border-radius:6px; font-size:15px;">
      </div>

      <button type="submit" class="btn" style="margin-top:8px;">Generate Guide</button>
    </form>
  </section>
</main>

<%- include('partials/footer') %>
