<%- include('partials/header', { pageTitle: 'Posting Report — Florida Buzz Admin', category: null, tickerItems: [], canonicalPath: null }) %>

<main class="wrap">
  <section class="section" style="max-width:720px; margin:0 auto;">
    <h1 style="font-family:var(--font-display); font-size:28px; color:var(--teal-900);">Posting Report</h1>
    <p style="color:var(--ink-600); margin-top:6px;">Post volume and success/failure across all platforms, tracked automatically every time a post goes out.</p>

    <% if (!hasData) { %>
      <div style="background:#fdecea; color:#b3261e; padding:12px 16px; border-radius:8px; margin-top:16px; font-size:14px;">Supabase isn't configured — no data available.</div>
    <% } %>

    <h2 style="font-size:16px; color:var(--teal-900); margin-top:28px;">Content</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:12px; margin-top:12px;">
      <div style="background:var(--teal-900); color:#fff; border-radius:10px; padding:16px; text-align:center;">
        <div style="font-family:var(--font-display); font-size:30px;"><%= totalArticles %></div>
        <div style="font-size:12px; color:#c9dedd; margin-top:4px;">Total Published</div>
      </div>
      <div style="background:#fff; border:1px solid var(--sand-100); border-radius:10px; padding:16px; text-align:center;">
        <div style="font-family:var(--font-display); font-size:30px; color:var(--teal-900);"><%= totalNews %></div>
        <div style="font-size:12px; color:var(--ink-600); margin-top:4px;">News Articles</div>
      </div>
      <div style="background:#fff; border:1px solid var(--sand-100); border-radius:10px; padding:16px; text-align:center;">
        <div style="font-family:var(--font-display); font-size:30px; color:var(--teal-900);"><%= totalGuides %></div>
        <div style="font-size:12px; color:var(--ink-600); margin-top:4px;">Evergreen Guides</div>
      </div>
    </div>

    <div style="background:var(--sand-100); border-radius:10px; padding:14px 18px; margin-top:12px; text-align:center;">
      <span style="font-size:14px; color:var(--ink-600);">
        🎯 <strong style="color:var(--teal-900);"><%= nextArticleMilestone - totalArticles %></strong> more to reach <strong style="color:var(--teal-900);"><%= nextArticleMilestone %></strong> total articles/guides
      </span>
    </div>

    <div style="display:flex; gap:12px; margin-top:12px;">
      <div style="flex:1; background:#fff; border:1px solid var(--sand-100); border-radius:10px; padding:14px; text-align:center;">
        <div style="font-family:var(--font-display); font-size:22px; color:var(--coral-600);"><%= last7DaysContent %></div>
        <div style="font-size:12px; color:var(--ink-600);">Published, last 7 days</div>
      </div>
      <div style="flex:1; background:#fff; border:1px solid var(--sand-100); border-radius:10px; padding:14px; text-align:center;">
        <div style="font-family:var(--font-display); font-size:22px; color:var(--coral-600);"><%= last30DaysContent %></div>
        <div style="font-size:12px; color:var(--ink-600);">Published, last 30 days</div>
      </div>
    </div>

    <div style="margin-top:16px;">
      <% categoryBreakdown.forEach(c => { %>
        <% const pct = totalArticles ? Math.round((c.count / totalArticles) * 100) : 0; %>
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:6px; font-size:13px;">
          <div style="width:130px; flex-shrink:0;"><%= c.label %></div>
          <div style="flex:1; background:var(--sand-100); border-radius:6px; height:16px; position:relative; overflow:hidden;">
            <div style="background:var(--teal-900); height:100%; width:<%= pct %>%;"></div>
          </div>
          <div style="width:40px; text-align:right; color:var(--ink-600);"><%= c.count %></div>
        </div>
      <% }) %>
    </div>

    <h2 style="font-size:16px; color:var(--teal-900); margin-top:32px;">Posting Health</h2>
    <p style="color:var(--ink-600); font-size:13px; margin-top:2px;">Success/failure across all platforms, tracked automatically every time a post goes out.</p>

    <div style="margin-top:16px; overflow-x:auto;">
      <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
          <tr style="background:var(--teal-900); color:white;">
            <th style="padding:10px 12px; text-align:left;">Platform</th>
            <th style="padding:10px 12px; text-align:center;">Yesterday (24h) ✅</th>
            <th style="padding:10px 12px; text-align:center;">Yesterday (24h) ❌</th>
            <th style="padding:10px 12px; text-align:center;">Rolling 7 Days ✅</th>
            <th style="padding:10px 12px; text-align:center;">Rolling 7 Days ❌</th>
          </tr>
        </thead>
        <tbody>
          <% platforms.forEach((platform, i) => { %>
            <tr style="background:<%= i % 2 === 0 ? '#fff' : 'var(--sand-100)' %>;">
              <td style="padding:10px 12px; font-weight:600; text-transform:capitalize;"><%= platform %></td>
              <td style="padding:10px 12px; text-align:center; color:#1b5e20; font-weight:600;"><%= summary[platform].last24h.success %></td>
              <td style="padding:10px 12px; text-align:center; color:<%= summary[platform].last24h.failed > 0 ? '#b3261e' : '#999' %>; font-weight:600;"><%= summary[platform].last24h.failed %></td>
              <td style="padding:10px 12px; text-align:center; color:#1b5e20; font-weight:600;"><%= summary[platform].last7d.success %></td>
              <td style="padding:10px 12px; text-align:center; color:<%= summary[platform].last7d.failed > 0 ? '#b3261e' : '#999' %>; font-weight:600;"><%= summary[platform].last7d.failed %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (recentFailures.length) { %>
      <div style="margin-top:32px;">
        <h2 style="font-size:16px; color:var(--teal-900);">Recent Failures (last 7 days)</h2>
        <div style="margin-top:10px; display:flex; flex-direction:column; gap:8px;">
          <% recentFailures.forEach(f => { %>
            <div style="background:#fdecea; border-radius:6px; padding:10px 14px; font-size:13px;">
              <strong style="text-transform:capitalize;"><%= f.platform %></strong>
              — <%= new Date(f.created_at).toLocaleString('en-US', { timeZone: 'America/New_York' }) %> ET
              <div style="color:#7a2018; margin-top:4px;"><%= f.detail || '(no detail)' %></div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } else { %>
      <p style="color:var(--ink-600); margin-top:24px; font-size:14px;">No failures in the last 7 days. 🎉</p>
    <% } %>

    <h2 style="font-size:16px; color:var(--teal-900); margin-top:32px;">Broken Links (404s)</h2>
    <p style="color:var(--ink-600); font-size:13px; margin-top:2px;"><%= total404sLast7d %> total hit(s) in the last 7 days (includes routine bot scanning traffic every site gets). Table below filters that out to show genuine content-link issues only.</p>

    <% if (top404s.length) { %>
      <div style="margin-top:12px; overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse; font-size:13px;">
          <thead>
            <tr style="background:var(--teal-900); color:white;">
              <th style="padding:8px 12px; text-align:left;">Path</th>
              <th style="padding:8px 12px; text-align:center;">Hits (30d)</th>
              <th style="padding:8px 12px; text-align:left;">Referrer</th>
              <th style="padding:8px 12px; text-align:left;">Last Seen</th>
            </tr>
          </thead>
          <tbody>
            <% top404s.forEach((r, i) => { %>
              <tr style="background:<%= i % 2 === 0 ? '#fff' : 'var(--sand-100)' %>;">
                <td style="padding:8px 12px; font-family:monospace; word-break:break-all;"><%= r.path %></td>
                <td style="padding:8px 12px; text-align:center; font-weight:600; color:#b3261e;"><%= r.count %></td>
                <td style="padding:8px 12px; color:var(--ink-600); word-break:break-all;"><%= r.referrer || '—' %></td>
                <td style="padding:8px 12px; color:var(--ink-600); white-space:nowrap;"><%= new Date(r.lastSeen).toLocaleDateString('en-US', { timeZone: 'America/New_York' }) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p style="color:var(--ink-600); margin-top:12px; font-size:14px;">No 404s logged in the last 30 days. 🎉</p>
    <% } %>

    <p style="color:#999; font-size:12px; margin-top:32px;">Refresh this page anytime — nothing to submit, just reload with the same link to see updated numbers.</p>
  </section>
</main>

<%- include('partials/footer') %>
