<%- include('partials/header', { pageTitle: (article.meta_title || article.title) + ' — The Florida Buzz', pageDescription: article.dek, category: article.category, tickerItems: ticker, canonicalPath: '/article/' + article.slug, pageImage: article.image_url || placeholderImg(article.category), ogType: 'article' }) %>

<main class="wrap">
  <article class="article-page">
    <span class="eyebrow"><%= categoryLabels[article.category] %></span>
    <h1><%= article.title %></h1>
    <p class="dek"><%= article.dek %></p>
    <p class="byline">By The Florida Buzz staff &middot; <%= timeAgo(article.published_at) %></p>

    <div class="hero-image" style="margin: 22px 0;">
      <img src="<%= article.image_url || placeholderImg(article.category) %>" alt="<%= article.title %>" width="800" height="600" loading="eager">
    </div>

    <div class="article-body"><%- article.body_html %></div>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      "headline": <%- JSON.stringify(article.title) %>,
      "description": <%- JSON.stringify(article.dek) %>,
      "image": [<%- JSON.stringify(article.image_url || placeholderImg(article.category)) %>],
      "datePublished": <%- JSON.stringify(new Date(article.published_at).toISOString()) %>,
      "dateModified": <%- JSON.stringify(new Date(article.published_at).toISOString()) %>,
      "author": {
        "@type": "Organization",
        "name": "Florida Buzz",
        "url": "<%= (process.env.SITE_URL || 'https://thefloridabuzz.com') %>"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Florida Buzz",
        "logo": {
          "@type": "ImageObject",
          "url": "<%= (process.env.SITE_URL || 'https://thefloridabuzz.com') %>/apple-touch-icon.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "<%= (process.env.SITE_URL || 'https://thefloridabuzz.com') + '/article/' + article.slug %>"
      }
    }
    </script>

    <% if (article.is_evergreen) { %>
    <p style="background: var(--sand-100); border-left: 3px solid var(--gold-500); padding: 12px 16px; font-size: 13px; color: var(--ink-600); margin-top: 24px;">
      <strong>Heads up:</strong> this guide may contain affiliate links. If you book or buy through them, we may earn a small commission at no extra cost to you — it helps keep The Florida Buzz running.
    </p>
    <% } %>

    <% if (article.is_evergreen) { %>
    <p class="source-note">
      Written and researched by The Florida Buzz staff.
    </p>
    <% } else { %>
    <p class="source-note">
      Originally reported by <a href="<%= article.source_url %>" target="_blank" rel="noopener"><%= article.source_name %></a>.
      The Florida Buzz summarizes official announcements in our own words and links back to the source.
    </p>
    <% } %>
  </article>

  <% if (related && related.length) { %>
  <section class="section">
    <div class="section-head"><span class="section-title">More <%= categoryLabels[article.category] %></span></div>
    <div class="grid">
      <% related.forEach(a => { %>
        <a href="/article/<%= a.slug %>" class="card">
          <div class="card-image"><img src="<%= a.image_url || placeholderImg(a.category) %>" alt="<%= a.title %>" width="480" height="300" loading="lazy"></div>
          <h3><%= a.title %></h3>
          <p class="dek-sm"><%= a.dek %></p>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>

<%- include('partials/footer') %>
