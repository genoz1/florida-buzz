<%- include('partials/header', { pageTitle: (typeof seoTitle !== 'undefined' && seoTitle ? seoTitle : categoryLabels[category]) + ' — The Florida Buzz', pageDescription: typeof seoDescription !== 'undefined' ? seoDescription : undefined, category, tickerItems: ticker, canonicalPath: '/category/' + category }) %>

<main class="wrap">
  <section class="section" style="border-bottom:none; padding-bottom:0;">
    <span class="eyebrow"><%= articles.length %> stories</span>
    <h1 style="font-family:var(--font-display); font-size:34px; color:var(--teal-900); margin:8px 0 0;"><%= categoryLabels[category] %></h1>
    <% if (typeof seoIntro !== 'undefined' && seoIntro) { %>
    <p style="color:var(--ink-600); max-width:640px; margin-top:10px;"><%= seoIntro %></p>
    <% } %>
    <% if (typeof cityLabels !== 'undefined' && cityLabels) { %>
    <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap;">
      <span style="font-family:var(--font-mono); font-size:12px; color:var(--ink-600); align-self:center;">Browse by area:</span>
      <% Object.keys(cityLabels).forEach(city => { %>
        <a href="/city/<%= city %>" style="font-size:13px; font-weight:600; padding:6px 12px; background:var(--sand-100); border-radius:20px; color:var(--teal-900);"><%= cityLabels[city] %></a>
      <% }) %>
    </div>
    <% } %>
  </section>

  <section class="section">
    <% if (!articles.length) { %>
      <p style="color:var(--ink-600);">Nothing published in this category yet — check back soon, or see <a href="/" style="color:var(--coral-600); font-weight:600;">everything we've got</a>.</p>
    <% } else { %>
    <div class="grid">
      <% articles.forEach(a => { %>
        <a href="/article/<%= a.slug %>" class="card">
          <div class="card-image"><img src="<%= a.image_url || placeholderImg(a.category) %>" alt="<%= a.title %>" width="480" height="300" loading="lazy" onerror="this.onerror=null;this.src='<%= placeholderImg(a.category) %>';"></div>
          <h3><%= a.title %></h3>
          <p class="dek-sm"><%= a.dek %></p>
          <p class="byline"><%= timeAgo(a.published_at) %></p>
        </a>
      <% }) %>
    </div>
    <% } %>
  </section>
</main>

<%- include('partials/footer') %>
