{
  "name": "florida-buzz",
  "version": "1.0.0",
  "description": "The Florida Buzz - automated Florida lifestyle & travel news site",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "automate": "node scripts/automate.js",
    "automate:dry": "DRY_RUN=true node scripts/automate.js",
    "newsletter": "node scripts/newsletter.js",
    "newsletter:dry": "DRY_RUN=true node scripts/newsletter.js",
    "guide-images": "node scripts/generate-guide-images.js",
    "guide:daily": "node scripts/generate-guide.js",
    "guide:daily:dry": "DRY_RUN=true node scripts/generate-guide.js",
    "promo": "node scripts/promo-post.js",
    "promo:dry": "DRY_RUN=true node scripts/promo-post.js",
    "backfill-images": "node scripts/backfill-images.js",
    "backfill-images:dry": "DRY_RUN=true node scripts/backfill-images.js",
    "fix-images": "node scripts/fix-specific-images.js",
    "fix-images:dry": "DRY_RUN=true node scripts/fix-specific-images.js",
    "crop-image": "node scripts/crop-existing-image.js",
