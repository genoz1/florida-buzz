    "city-roundup:dry": "DRY_RUN=true node scripts/city-roundup.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "image-size": "^1.1.1",
    "jimp": "^1.6.1",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
